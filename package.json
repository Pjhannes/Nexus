{
  "name": "nexus",
  "version": "0.3.1",
  "description": "MCP-Server + Web-UI fuer Pauls Knowledge-Base",
  "author": "Paul-Johannes Hunold",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "node src/server.js",
    "mcp": "node src/server.js",
    "ui": "node src/ui-server.js",
    "index": "node src/cli.js reindex",
    "test": "node test/smoke.js",
    "app": "electron electron/main.js",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --dir",
    "gen:icon": "node scripts/gen-icon.mjs",
    "verify:html": "node scripts/verify-html.mjs public/index.html",
    "edit:html": "node scripts/safe-edit.mjs public/index.html",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chokidar": "^4.0.0",
    "express": "^4.19.0",
    "multer": "^1.4.5-lts.1",
    "yaml": "^2.4.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.0"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "de.hunold.nexus",
    "productName": "Nexus",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "legalTrademarks": "Nexus"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "installerLanguages": [
        "de_DE",
        "en_US"
      ],
      "language": "1031",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nexus",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "Nexus-${version}-portable.exe"
    }
  }
}
