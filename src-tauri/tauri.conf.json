{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Nexus",
  "version": "../package.json",
  "identifier": "com.nexusapp.nexus",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3002",
    "beforeDevCommand": "node scripts/dev-tauri.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/node"],
    "resources": {
      "../src": "src",
      "../public": "public",
      "../package.json": "package.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
